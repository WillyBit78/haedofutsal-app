{
  "name": "Haedo Futsal Club",
  "short_name": "Haedo Futsal",
  "description": "Sistema de Gestión y Finanzas de Haedo Futsal Club",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#0f172a",
  "theme_color": "#1d4ed8",
  "status_bar": "black-translucent",
  "icons": [
    {
      "src": "logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/share-receipt",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "receipt",
          "accept": [
            "image/*",
            "application/pdf"
          ]
        }
      ]
    }
  }
}
